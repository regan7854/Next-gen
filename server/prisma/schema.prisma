generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String                  @id @default(uuid())
  username      String                  @unique
  displayName   String                  @map("display_name")
  email         String                  @unique
  passwordHash  String                  @map("password_hash")
  role          String                  @default("user")
  biography     String?
  avatarColor   String?                 @map("avatar_color")
  location      String?
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @default(now()) @updatedAt @map("updated_at")

  influencerProfile InfluencerProfile?
  brandProfile      BrandProfile?
  sentRequests      CollaborationRequest[] @relation("CollabSender")
  receivedRequests  CollaborationRequest[] @relation("CollabReceiver")
  campaigns         Campaign[]
  reviewsWritten    Review[]              @relation("Reviewer")
  reviewsReceived   Review[]              @relation("Reviewee")
  notifications     Notification[]
  negotiationMessages NegotiationMessage[]

  @@map("users")
}

model InfluencerProfile {
  userId               String   @id @map("user_id")
  category             String?
  niche                String?
  instagramHandle      String?  @map("instagram_handle")
  instagramFollowers   Int      @default(0) @map("instagram_followers")
  instagramEngagement  Float    @default(0) @map("instagram_engagement")
  tiktokHandle         String?  @map("tiktok_handle")
  tiktokFollowers      Int      @default(0) @map("tiktok_followers")
  tiktokAvgViews       Int      @default(0) @map("tiktok_avg_views")
  youtubeHandle        String?  @map("youtube_handle")
  youtubeSubscribers   Int      @default(0) @map("youtube_subscribers")
  youtubeAvgViews      Int      @default(0) @map("youtube_avg_views")
  audienceAgeRange     String?  @map("audience_age_range")
  audienceLocation     String?  @map("audience_location")
  minRate              Int      @default(0) @map("min_rate")
  maxRate              Int      @default(0) @map("max_rate")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("influencer_profiles")
}

model BrandProfile {
  userId              String   @id @map("user_id")
  companyName         String?  @map("company_name")
  industry            String?
  website             String?
  productType         String?  @map("product_type")
  targetAudience      String?  @map("target_audience")
  campaignGoals       String?  @map("campaign_goals")
  minBudget           Int      @default(0) @map("min_budget")
  maxBudget           Int      @default(0) @map("max_budget")
  preferredPlatforms  String?  @map("preferred_platforms")
  preferredCategories String?  @map("preferred_categories")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("brand_profiles")
}

model CollaborationRequest {
  id           String   @id @default(uuid())
  senderId     String   @map("sender_id")
  receiverId   String   @map("receiver_id")
  message      String?
  status       String   @default("pending")
  campaignTitle String? @map("campaign_title")
  budgetOffered Int?    @map("budget_offered")
  tenureDays    Int?    @map("tenure_days")
  tenureValue   Int?    @map("tenure_value")
  tenureUnit    String? @map("tenure_unit")
  acceptedAt    DateTime? @map("accepted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  sender   User @relation("CollabSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("CollabReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  reviews  Review[]
  negotiationMessages NegotiationMessage[]

  @@map("collaboration_requests")
}

model Campaign {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  title         String
  description   String?
  platform      String?
  resultsSummary String? @map("results_summary")
  reach         Int      @default(0)
  engagement    Int      @default(0)
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("campaigns")
}

model Review {
  id              String   @id @default(uuid())
  reviewerId      String   @map("reviewer_id")
  revieweeId      String   @map("reviewee_id")
  collabRequestId String?  @map("collab_request_id")
  rating          Int
  comment         String?
  createdAt       DateTime @default(now()) @map("created_at")

  reviewer User @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  collabRequest CollaborationRequest? @relation(fields: [collabRequestId], references: [id])

  @@map("reviews")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String?
  relatedId String?  @map("related_id")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model NegotiationMessage {
  id            String   @id @default(uuid())
  requestId     String   @map("request_id")
  senderId      String   @map("sender_id")
  message       String?
  proposedBudget Int     @default(0) @map("proposed_budget")
  action        String   @default("counter")
  createdAt     DateTime @default(now()) @map("created_at")

  request CollaborationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender  User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("negotiation_messages")
}
